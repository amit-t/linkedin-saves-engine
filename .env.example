# Required only for real Notion writes / database creation.
NOTION_TOKEN=secret_xxx

# Required for setup:notion-schema --write.
# Create/share a parent page with your Notion integration, then paste page ID here.
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filled after setup:notion-schema --write or manual DB setup.
NOTION_RAW_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_IDEAS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional persistent browser profile for LinkedIn capture.
LINKEDIN_BROWSER_PROFILE=.browser-profiles/linkedin
