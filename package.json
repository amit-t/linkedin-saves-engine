{
  "name": "linkedin-saves-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first LinkedIn saves to Notion raw ingest and content ideas engine.",
  "bin": {
    "linkedin-saves-engine": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
