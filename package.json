    "doctor": "tsx src/cli.ts doctor"
  },
  "dependencies": {
    "@notionhq/client": "latest",
    "commander": "latest",
    "playwright": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
